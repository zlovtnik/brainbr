DB_PASSWORD=changeme_in_production
DB_USER=fiscal_user
DATABASE_URL=jdbc:postgresql://localhost:5432/fiscalbrain
DB_POOL_MAX=10
OPENAI_API_KEY=sk-...
APP_PROVIDERS_OPENAI_API_KEY=${OPENAI_API_KEY}
MODEL_PROVIDER_MODE=real

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
WORKER_HEARTBEAT_INTERVAL_MS=60000
WORKER_INGESTION_POLL_INTERVAL_MS=2000
WORKER_AUDIT_POLL_INTERVAL_MS=2000
APP_QUEUE_RETRY_MAX_ATTEMPTS=3
APP_QUEUE_RETRY_BASE_BACKOFF_MS=1000

ENVIRONMENT=development
LOG_LEVEL=INFO

APP_SECURITY_JWT_ISSUER_URI=https://auth.example.com
APP_SECURITY_JWT_JWK_SET_URI=http://localhost:8081/.well-known/jwks.json
APP_SECURITY_JWT_TENANT_CLAIM=tenant_id
APP_SECURITY_JWT_ENABLED=true
APP_BYPASS_RLS_ENABLED=true
API_BASE_URL=http://localhost:8080
APP_SESSION_SECRET=change-me-for-sveltekit
# Configure at least one: APP_SECURITY_JWT_ISSUER_URI or APP_SECURITY_JWT_JWK_SET_URI
