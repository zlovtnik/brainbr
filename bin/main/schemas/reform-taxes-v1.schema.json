{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fiscalbrain-br/docs/schemas/reform-taxes-v1.schema.json",
  "title": "ReformTaxesV1",
  "type": "object",
  "required": ["ibs", "cbs", "tax_rate", "is_taxable"],
  "additionalProperties": false,
  "properties": {
    "ibs": { "type": "number", "minimum": 0 },
    "cbs": { "type": "number", "minimum": 0 },
    "tax_rate": { "type": "number", "minimum": 0 },
    "is_taxable": { "type": "boolean" },
    "cashback_eligible": { "type": "boolean" },
    "regime": { "type": "string" },
    "reduced_basket": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
