{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fiscalbrain-br.example/schemas/explainability-artifact-v1.schema.json",
  "title": "ExplainabilityArtifactV1",
  "type": "object",
  "required": [
    "sku_id",
    "job_id",
    "artifact_version",
    "schema_version",
    "llm_model_used",
    "vector_id",
    "audit_confidence",
    "source_snapshot",
    "replay_context",
    "rag_output",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "sku_id": { "type": "string", "minLength": 1 },
    "job_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": ["string", "null"] },
    "artifact_version": { "type": "string", "const": "explainability-artifact-v1" },
    "schema_version": { "type": "string", "minLength": 1 },
    "llm_model_used": { "type": "string", "minLength": 1 },
    "vector_id": { "type": "string", "format": "uuid" },
    "audit_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_snapshot": {
      "type": "object",
      "required": ["law_ref", "content", "source_url"],
      "additionalProperties": false,
      "properties": {
        "law_ref": { "type": "string", "minLength": 1 },
        "content": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" }
      }
    },
    "replay_context": {
      "type": "object",
      "required": ["retrieval_query", "top_k", "selected_chunk_id", "candidate_chunks"],
      "additionalProperties": true,
      "properties": {
        "retrieval_query": { "type": "string", "minLength": 1 },
        "top_k": { "type": "integer", "minimum": 1 },
        "selected_chunk_id": { "type": "string", "format": "uuid" },
        "candidate_chunks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["chunk_id", "law_ref", "score"],
            "additionalProperties": true,
            "properties": {
              "chunk_id": { "type": "string", "format": "uuid" },
              "law_ref": { "type": "string", "minLength": 1 },
              "score": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "rag_output": {
      "type": "object",
      "required": ["reform_taxes", "audit_confidence", "llm_model_used", "source"],
      "additionalProperties": false,
      "properties": {
        "reform_taxes": {
          "type": "object",
          "required": ["ibs", "cbs", "tax_rate", "is_taxable"],
          "additionalProperties": false,
          "properties": {
            "ibs": { "type": "number", "minimum": 0 },
            "cbs": { "type": "number", "minimum": 0 },
            "tax_rate": { "type": "number", "minimum": 0 },
            "is_taxable": { "type": "boolean" },
            "cashback_eligible": { "type": "boolean" },
            "regime": { "type": "string" },
            "reduced_basket": { "type": "boolean" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "audit_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "llm_model_used": {"type": "string", "minLength": 1},
        "source": {
          "type": "object",
          "required": ["law_ref", "content", "source_url"],
          "additionalProperties": false,
          "properties": {
            "law_ref": {"type": "string", "minLength": 1},
            "content": {"type": "string", "minLength": 1},
            "source_url": {"type": "string", "format": "uri"}
          }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
