API_BASE_URL=http://localhost:8080
APP_SESSION_SECRET=a-string-secret-at-least-256-bits-long
APP_AUTH_HARDCODED_USERNAME=YOUR_USERNAME
APP_AUTH_HARDCODED_PASSWORD=YOUR_PASSWORD
# Required for quick login and password login: must be a backend-signed JWT token (not a sample/test token).
# This token must be signed by the issuer/JWKS configured for the backend API and include the scopes
# needed for the routes you use. Never check real tokens into source control; supply your own secrets locally.
APP_AUTH_HARDCODED_TOKEN=YOUR_BACKEND_SIGNED_TOKEN
